name: Pylint

on: [push]

jobs:
  build:
    runs-on: ubuntu-latest
    strategy:
      matrix:
        python-version: ["3.10", "3.11", "3.12"]
    steps:
    - uses: actions/checkout@v4
    
    - name: Set up Python ${{ matrix.python-version }}
      uses: actions/setup-python@v5
      with:
        python-version: ${{ matrix.python-version }}
        
    - name: Instalar Dependências
      run: |
        python -m pip install --upgrade pip
        pip install pylint
        
        # 1. Instala as dependências mapeadas no seu requirements.txt
        if [ -f requirements.txt ]; then pip install -r requirements.txt; fi
        
        # 2. Garante explicitamente os pacotes de IA e MCP para eliminar de vez o erro E0401
        pip install google-genai pydantic tiktoken transformers requests python-dotenv mcp
        
    - name: Analisar código com o Pylint
      run: |
        pylint $(git ls-files '*.py')